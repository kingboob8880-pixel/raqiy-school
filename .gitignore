# Сырой экспорт Telegram — личные фото/голосовые/переписка, не для публикации.
# Помимо личных данных, здесь же лежат все 25 исходных PDF (включая
# исключённые из курса книги) — публиковать их значит обойти весь триаж §9а.
/tg/
messages.html
result.json

# Дизайн-референс — большой bundled-артефакт, не нужен для работы сайта.
Онлайн-школа рукии - концепция.html
Лендинг - новый фон.html

# ⚠️ Ключи Firebase — заполняются вручную, не должны попасть в публичную историю
# коммитов до перехода на приватный репозиторий с ограниченным доступом.
integration/firebase-config.local.js

# Секреты (GitHub-токены и т.п.) — никогда не коммитить.
.env

# RUKYA PRO desktop (Electron-обёртка над tg/files/rukya_p_4/…) — отдельный
# продукт для выпускников курса, не часть сайта. node_modules/dist/release
# генерируются локально при сборке (BUILD_EXE.bat) — тяжёлые, платформо-
# зависимые, не для git (2026-07-20).
/rukya-pro-desktop/node_modules/
/rukya-pro-desktop/dist/
/rukya-pro-desktop/release/
