rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    // Раздел "Архив" (content/_content_archive_index_md — bookKey() от
    // "/content/archive/index.md") разбирает материалы, исключённые из
    // сертифицируемой программы, с прямой критикой конкретных книг/методик.
    // Автор попросил "убери от всех кроме меня админа" (2026-07-21) — на
    // клиенте (pages/book.html) уже сделано, но реальная защита живёт
    // здесь: без этой правки любой ОПЛАТИВШИЙ курс ученик всё равно мог бы
    // прочитать полный текст прямым запросом к Firestore (SDK/консоль),
    // в обход JS-стены — то же рассуждение, что и у общего правила ниже
    // ("реальная защита пейвола вместо визуальной").
    function isArchiveDoc(docId) {
      return docId == '_content_archive_index_md';
    }

    match /admins/{uid} {
      // Список админов не создаётся через клиент — только вручную в консоли Firebase
      // (integration/README.md, шаг "Первый админ"), чтобы никто не мог сам себя
      // назначить админом через клиентский код.
      allow read: if isOwner(uid) || isAdmin();
      allow write: if false;
    }

    match /students/{uid} {
      allow create: if isOwner(uid);
      allow read: if isOwner(uid) || isAdmin();
      // Ученик правит свой профиль/прогресс, но не поле paid — это переключает
      // только админ вручную (project.md §18).
      allow update: if (isOwner(uid) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['paid']))
                    || isAdmin();
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if isOwner(uid) || isAdmin();
        // from обязан совпадать с реальной ролью пишущего — иначе ученик
        // может подделать сообщение "от админа" в своей же переписке.
        allow create: if (isOwner(uid) && request.resource.data.from == 'student')
                      || (isAdmin() && request.resource.data.from == 'admin');
        allow update, delete: if isAdmin();
      }
    }

    // Полный текст платных книг/модулей (docId = bookKey() из
    // pages/js/modules-data.js). Реальная защита пейвола вместо визуальной
    // (project.md §18/§22, задача "закрыть дыру с платным контентом",
    // 2026-07-20): до этого полный текст лежал открытым в content/*.md на
    // GitHub независимо от статуса оплаты. Пишет сюда только скрипт
    // scripts/seed-paid-content.mjs через Admin SDK от имени автора курса —
    // клиентской записи с этой коллекцией не предполагается вовсе.
    match /content/{docId} {
      // Архив — исключение из общего правила "оплатил → читает всё": даже
      // paid == true не даёт доступа к этому docId, только isAdmin().
      allow read: if isAdmin()
                  || (!isArchiveDoc(docId) && isSignedIn()
                      && get(/databases/$(database)/documents/students/$(request.auth.uid)).data.paid == true);
      allow write: if false;
    }
  }
}
