rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    match /admins/{uid} {
      // Список админов не создаётся через клиент — только вручную в консоли Firebase
      // (integration/README.md, шаг "Первый админ"), чтобы никто не мог сам себя
      // назначить админом через клиентский код.
      allow read: if isOwner(uid) || isAdmin();
      allow write: if false;
    }

    match /students/{uid} {
      allow create: if isOwner(uid);
      allow read: if isOwner(uid) || isAdmin();
      // Ученик правит свой профиль/прогресс, но не поле paid — это переключает
      // только админ вручную (project.md §18).
      allow update: if (isOwner(uid) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['paid']))
                    || isAdmin();
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if isOwner(uid) || isAdmin();
        allow create: if isOwner(uid) || isAdmin();
        allow update, delete: if isAdmin();
      }
    }
  }
}
